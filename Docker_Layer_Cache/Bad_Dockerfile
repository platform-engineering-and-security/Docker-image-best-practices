FROM ubuntu:22.04

WORKDIR /app

# Layers which keep changing and should be at the end.

COPY src /src


# --- Uneccesary multiple layers

RUN apt update -y
RUN apt upgrade -y
RUN apt install -y curl
RUN apt install -y unzip
RUN curl -L -o my-app.zip https://example.com/releases/app-${APP_VERSION}.zip
RUN unzip my-app.zip

# --- 

ENV PATH=/root/.local/bin:$PATH
CMD ["./my-app-binary"]
